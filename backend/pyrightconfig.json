{
  "pythonVersion": "3.12",
  "typeCheckingMode": "strict",
  "stubPath": "typings",
  "venvPath": ".",
  "venv": ".venv",
  "exclude": [
    "tests",
    "services/depth_processor_pipeline/depth_anything_v2",
    ".venv",
    "node_modules",
    "dist",
    "tmp",
    "scripts",
    "profile_results",
    "services/patches",
    "services/trainer_target/ssh_remote.py",
    "services/trainer_target/ssh_keys.py",
    "services/trainer_target/runpod_trainer_target.py"
  ],
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": false,
  "reportUnknownMemberType": true,
  "reportUnknownVariableType": true,
  "reportUnknownArgumentType": true,
  "reportUnknownParameterType": true,
  "reportUnusedImport": "warning",
  "reportUnusedVariable": "warning"
}
